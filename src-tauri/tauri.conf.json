{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QxChat",
  "version": "1.0.0",
  "identifier": "com.qxp.client",
  "build": {
    "beforeDevCommand": "cd client && bun install --no-save && bun vite --host 0.0.0.0",
    "beforeBuildCommand": "cd client && bun run build:tauri",
    "devUrl": "http://localhost:4173/#/",
    "frontendDist": "../client/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "QxChat",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "iOS": {
      "minimumSystemVersion": "14.0",
      "developmentTeam": null
    }
  }
}
