{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LQXP Client",
  "version": "1.0.0",
  "identifier": "com.qxp.client",
  "build": {
    "devUrl": "https://qxp.kisakay.com/#/",
    "frontendDist": "https://qxp.kisakay.com/#/"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LQXP Client",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
